# ──────────────────────────────────────────────────────────────────────────────
# .env.example  —  Environment variable template
#
# INSTRUCTIONS:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in your Binance Futures Testnet credentials below.
#   3. NEVER commit your real .env file to version control.
#
# Get Testnet credentials at: https://testnet.binancefuture.com
# ──────────────────────────────────────────────────────────────────────────────

# ── Binance Futures Testnet API Credentials ────────────────────────────────────

# Your Testnet API key (not your real Binance key).
BINANCE_API_KEY=your_testnet_api_key_here

# Your Testnet API secret (not your real Binance secret).
BINANCE_API_SECRET=your_testnet_api_secret_here

# ── Optional Configuration ─────────────────────────────────────────────────────

# Log verbosity for the file handler: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default if unset: DEBUG
# LOG_LEVEL=DEBUG
